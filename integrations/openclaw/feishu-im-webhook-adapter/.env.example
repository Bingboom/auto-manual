FEISHU_IM_VERIFICATION_TOKEN=replace-with-feishu-event-subscription-token
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
AUTO_MANUAL_REPO_ROOT=/absolute/path/to/auto-manual
AUTO_MANUAL_CONTROL_CONFIG=config.us.yaml

# Optional
# FEISHU_IM_WEBHOOK_HOST=127.0.0.1
# FEISHU_IM_WEBHOOK_PORT=9097
# FEISHU_IM_WEBHOOK_PATH=/feishu/events
# FEISHU_IM_HEALTH_PATH=/healthz
# FEISHU_IM_REQUIRE_MENTION=true
# FEISHU_IM_PUBLISH_CONFIRM_TTL_SECONDS=600
# FEISHU_IM_STATE_FILE=/absolute/path/to/auto-manual/.tmp/feishu-im-webhook-adapter/state.json
