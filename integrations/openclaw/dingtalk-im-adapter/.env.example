# DingTalk IM standalone adapter (Pattern B) runtime env.
# Copy to a PRIVATE file (e.g. ~/.auto-manual/dingtalk-im-adapter.env, chmod 600)
# and fill in real values. Do NOT commit the filled-in file — secrets stay
# per-machine; the repo only ships this template.
#
# NOTE: this standalone adapter is the DETERMINISTIC queue-driver alternative,
# NOT the BlockClaw persona path. For the persona path, configure
# channels.ddingtalk in ~/.openclaw/openclaw.json instead (see
# user-guide/dingtalk_blockclaw_bot_setup_guide.md and
# ../openclaw.ddingtalk.example.json).

# DingTalk app AppKey / Client ID + AppSecret / Client Secret (a DIFFERENT app
# from the one the gateway channels.ddingtalk uses — one robot's Stream cannot
# be consumed by two processes).
export DINGTALK_IM_CLIENT_ID="REPLACE_WITH_DINGTALK_CLIENT_ID"
export DINGTALK_IM_CLIENT_SECRET="REPLACE_WITH_DINGTALK_CLIENT_SECRET"

# Comma-separated DingTalk staffId(s) allowed to drive the bot.
# Empty = fail-closed (ignores everyone). Get yours via the log bootstrap.
export DINGTALK_IM_ALLOW_FROM="REPLACE_WITH_YOUR_STAFF_ID"

export AUTO_MANUAL_REPO_ROOT="/path/to/auto-manual"
export AUTO_MANUAL_CONTROL_CONFIG="configs/config.us.yaml"

# Optional: source your Feishu phase2 env too so build.py queue-* can read the
# Feishu Bitable, e.g. before launch: . ~/.auto_manual_feishu_phase2_env.sh
