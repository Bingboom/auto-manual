  <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/HB Safety Lead">
    <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]"><Content>SAVE THESE INSTRUCTIONS</Content></CharacterStyleRange><CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]"><Br/></CharacterStyleRange>
  </ParagraphStyleRange>
  <ParagraphStyleRange LeftIndent="3.7" FirstLineIndent="-6.25" RightIndent="0" Hyphenation="false" AppliedParagraphStyle="ParagraphStyle/HB Safety List">
    <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Content>• Stop using the product immediately if it shows signs of damage.</Content></CharacterStyleRange><CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Br/></CharacterStyleRange>
  </ParagraphStyleRange>
  <ParagraphStyleRange LeftIndent="3.7" FirstLineIndent="-6.25" RightIndent="0" Hyphenation="false" AppliedParagraphStyle="ParagraphStyle/HB Safety List">
    <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Content>• Do not charge the battery in extremely hot or cold environments and strictly adhere to the specified operating temperature ranges:</Content></CharacterStyleRange><CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Br/></CharacterStyleRange>
  </ParagraphStyleRange>
  <ParagraphStyleRange SpaceBefore="0.45" LeftIndent="9.58" FirstLineIndent="-6.04" RightIndent="0" Hyphenation="false" AppliedParagraphStyle="ParagraphStyle/HB Safety Sublist">
    <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Content>– Charging temperature: 0°C to 40°C (32°F to 104°F)</Content></CharacterStyleRange><CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Br/></CharacterStyleRange>
  </ParagraphStyleRange>
  <ParagraphStyleRange LeftIndent="9.58" FirstLineIndent="-6.04" RightIndent="0" Hyphenation="false" AppliedParagraphStyle="ParagraphStyle/HB Safety Sublist">
    <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Content>– Discharging temperature: -10°C to 40°C (14°F to 104°F)</Content></CharacterStyleRange><CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Br/></CharacterStyleRange>
  </ParagraphStyleRange>
  <ParagraphStyleRange LeftIndent="3.7" FirstLineIndent="-6.25" RightIndent="0" Hyphenation="false" AppliedParagraphStyle="ParagraphStyle/HB Safety List">
    <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]" HorizontalScale="98"><Content>• Unplug the power cord from a power outlet during a storm.</Content></CharacterStyleRange>
  </ParagraphStyleRange>
