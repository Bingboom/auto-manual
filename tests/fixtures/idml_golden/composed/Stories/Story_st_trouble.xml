  <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/HB%20Spec%20Value">
    <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]"><Content>Connect the product to loads to discharge its battery until the fault disappears.</Content></CharacterStyleRange>
  </ParagraphStyleRange>
    </Cell>
