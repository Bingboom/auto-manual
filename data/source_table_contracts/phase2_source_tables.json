{
  "schema_version": "phase2-source-table-contract/v1",
  "updated": "2026-06-29",
  "purpose": "Machine-readable contract for phase2 source tables used by source intake, cloud-doc backport, source-table writeback, sync-data, and build/review flows.",
  "source_of_truth": {
    "phase2_base": "Feishu phase2 source tables",
    "translation_memory_base": "Feishu Translation_Memory base",
    "snapshot_root": "data/phase2",
    "rule": "Online tables are the source of truth. data/phase2 CSVs are generated snapshots/read models and must not be hand-edited."
  },
  "global_write_rules": [
    "live writes are dry-run by default",
    "human approval is required before any source-table write",
    "record_id resolution is exact-or-abstain through source_record_index.json",
    "formula, lookup, link, attachment, and workflow/progress fields are not direct write targets",
    "create/upsert of new source rows remains review-only unless a table-specific create contract is added"
  ],
  "tables": [
    {
      "contract_name": "Spec_Master",
      "online_table": {
        "base": "phase2",
        "display_name": "03_内容源_规格参数明细",
        "reference_table_id": "tblTw54UzV4ry5VD"
      },
      "snapshot": {
        "logical_name": "spec_master",
        "file": "Spec_Master.csv",
        "row_filter": "Page is blank or includes specifications"
      },
      "identity": {
        "business_key_fields": ["document_key", "Row_key", "Slot_key"],
        "optional_key_fields": ["Slot_key"],
        "fallback_key_fields": ["Line_order", "Section"],
        "source_record_index_table": "Spec_Master",
        "source_ref_fields": {
          "document_key": "document_key",
          "row_key": "Row_key",
          "slot_key": "Slot_key",
          "line_order": "Line_order",
          "section": "Section"
        }
      },
      "intake": {
        "target_table": "Spec_Master",
        "supported": true,
        "candidate_fields": [
          "document_key",
          "Model",
          "Region",
          "Source_lang",
          "Version",
          "Is_Latest",
          "Page",
          "Section",
          "Section_order",
          "Row_order",
          "Row_key",
          "Slot_key",
          "Row_label_source",
          "Row_label_footnote_refs",
          "Line_order",
          "Param_source",
          "Param_footnote_refs",
          "Value_source",
          "Value_footnote_refs"
        ],
        "existing_row_change_request": true,
        "new_row_live_write": false
      },
      "writeback": {
        "change_request_update": true,
        "table_binding_name": "Spec_Master",
        "writable_fields": [
          "Row_label_source",
          "Row_label_footnote_refs",
          "Param_source",
          "Param_footnote_refs",
          "Value_source",
          "Value_footnote_refs"
        ],
        "blocked_field_kinds": ["formula", "lookup", "link", "attachment", "checkbox", "workflow"]
      },
      "commands": {
        "sync": "python build.py sync-data --config configs/config.us.yaml --data-root data/phase2 --table spec_master",
        "intake": "python tools/source_intake.py run --input <spec.md-or-doc-url> --document-key <MODEL_REGION> --source-lang en --data-root data/phase2",
        "backport": "python tools/cloud_doc_backport.py run-review-branch --doc-name <doc-name> --cloud-doc <url>"
      },
      "skills": ["spec-sheet-structured-intake", "manual-revision-backport", "manual-rewrite-with-tm"]
    },
