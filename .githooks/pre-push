#!/bin/sh
set -eu

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
repo_root="$(CDPATH= cd -- "${script_dir}/.." && pwd)"
cd "${repo_root}"

if [ -n "${PYTHON:-}" ]; then
  python_cmd="${PYTHON}"
elif [ -x "${repo_root}/.venv/bin/python" ]; then
  python_cmd="${repo_root}/.venv/bin/python"
elif [ -x "${repo_root}/.venv/Scripts/python.exe" ]; then
  python_cmd="${repo_root}/.venv/Scripts/python.exe"
elif command -v python3 >/dev/null 2>&1; then
  python_cmd="python3"
elif command -v python >/dev/null 2>&1; then
  python_cmd="python"
else
  echo "[pre-push] Python 3 is required to run scripts/git_branch_guard.py." >&2
  exit 1
fi

# Advisory (non-blocking): if this push changes shared templates/manifests,
# remind that open review/* branches hold frozen derivatives and must be
# refreshed via sync-review (merge_params). Never blocks the push (|| true);
# only reaches the review remote when shared source actually changed.
"${python_cmd}" "${repo_root}/tools/check_review_branch_sync.py" \
  --repo-root "${repo_root}" \
  --base "origin/${AUTO_MANUAL_BASE_BRANCH:-main}" \
  --remote "${REVIEW_REMOTE:-hello-docs}" || true

exec "${python_cmd}" "${repo_root}/scripts/git_branch_guard.py" \
  pre-push \
  --repo-root "${repo_root}" \
  --remote "${1:-origin}" \
  --base-branch "${AUTO_MANUAL_BASE_BRANCH:-main}"
