# Copy this file to .tmp/hello-docs-binding/env.sh and fill it locally.
# .tmp/ is gitignored. Do not put real secrets in this committed template.
#
# Usage:
#   scripts/configure_hello_docs_binding.sh --env-file .tmp/hello-docs-binding/env.sh --dry-run --include-optional
#   scripts/configure_hello_docs_binding.sh --env-file .tmp/hello-docs-binding/env.sh --include-optional
#   scripts/configure_hello_docs_binding.sh --env-file .tmp/hello-docs-binding/env.sh --include-optional --unpause

